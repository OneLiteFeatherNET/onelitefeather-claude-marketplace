{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Claude Code — Serena A/B (Tokens & Cost)",
  "uid": "serena-ab",
  "schemaVersion": 39,
  "tags": ["claude-code", "serena", "otel"],
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Total tokens — baseline vs serena",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "orientation": "horizontal" },
      "targets": [
        {
          "expr": "sum by (condition) (claude_code_token_usage_tokens_total)",
          "legendFormat": "{{condition}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Uncached input tokens (the real cost driver)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        {
          "expr": "sum by (condition) (claude_code_token_usage_tokens_total{type=\"input\"})",
          "legendFormat": "{{condition}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Tokens by type (input/output/cacheRead/cacheCreation)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "orientation": "horizontal", "stacking": "normal" },
      "targets": [
        {
          "expr": "sum by (condition, type) (claude_code_token_usage_tokens_total)",
          "legendFormat": "{{condition}} — {{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Tokens by MCP server (shows the Serena share)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "expr": "sum by (condition, mcp_server_name) (claude_code_token_usage_tokens_total)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token rate over time (per condition)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (condition) (rate(claude_code_token_usage_tokens_total[1m]))",
          "legendFormat": "{{condition}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cost (USD) — baseline vs serena",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [
        {
          "expr": "sum by (condition) (claude_code_cost_usage_USD_total)",
          "legendFormat": "{{condition}}",
          "refId": "A"
        }
      ]
    }
  ]
}
